// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Stage 1 — trivial model to prove DB connectivity end-to-end.
// Not part of the real domain schema (that comes in a later stage).
model HealthCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

// Tenant root. Every tenant-scoped table will carry organizationId and filter
// on it (row-level tenancy). `slug` backs the per-org login page.
// See design-docs/04-data-model.md — Tenancy & identity.
model Organization {
  id                String            @id @default(uuid())
  slug              String            @unique
  name              String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  // Stage 2 relations
  roles             Role[]
  externalCompanies ExternalCompany[]
  users             User[]
  // Stage 3 relations
  catalogItems      CatalogItem[]
  itemPrices        ItemPrice[]
  // Stage 5 relations
  componentCategories ComponentCategory[]
  componentTypes    ComponentType[]
  projects          Project[]
  // Stage 6 relations
  selections        Selection[]
  // Stage 7 relations
  inquiries         Inquiry[]
  // Stage 8 relations
  floors            Floor[]
  partitions        Partition[]
}

// ────────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────────

enum ExternalCompanyType {
  DISTRIBUTOR
  ARCHITECTURAL_FIRM
}

// ────────────────────────────────────────────────────────────
// better-auth tables (hand-authored — do NOT run better-auth
// CLI generate; it uses Kysely and doesn't understand Prisma 7's
// prisma-client generator).  Prisma model names are PascalCase
// (required by Prisma); @@map directives give lowercase table
// names in the DB, which is the convention better-auth documents.
// The prisma adapter accesses these via prisma.user, prisma.session,
// prisma.account, prisma.verification — exactly what PascalCase
// model names produce in the generated client.
// ────────────────────────────────────────────────────────────

model User {
  // Standard better-auth core fields
  id            String   @id @default(uuid())
  name          String
  // synthetic auth key {username}@{orgSlug}.internal — NOT a real email
  // TODO: if enabling email features, migrate email field first
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Domain additionalFields (stored inline on the user table)
  organizationId    String
  username          String
  active            Boolean @default(true)
  roleId            String
  externalCompanyId String?
  // Real user email (if any) lives here — separate from the synthetic auth key above
  profileEmail      String?

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id])
  role            Role             @relation(fields: [roleId], references: [id])
  externalCompany ExternalCompany? @relation(fields: [externalCompanyId], references: [id])
  sessions          Session[]
  accounts          Account[]
  createdProjects   Project[]
  createdInquiries  Inquiry[]

  // Per-org username uniqueness — the actual uniqueness guarantee;
  // the synthetic email is only better-auth's carrier for it.
  @@unique([organizationId, username])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 2: permissions, roles, external companies
// ────────────────────────────────────────────────────────────

// Global permission catalog — not org-scoped (codes are shared across all orgs).
model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String
  roles       RolePermission[]
}

// Per-org roles. The same role name (e.g. "Admin") can exist in every org.
model Role {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  description    String?
  organization   Organization     @relation(fields: [organizationId], references: [id])
  permissions    RolePermission[]
  users          User[]

  @@unique([organizationId, name])
}

// Junction table: which permissions a role has.
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// External companies (distributors, architectural firms) that belong to an org.
model ExternalCompany {
  id             String              @id @default(uuid())
  organizationId String
  type           ExternalCompanyType
  name           String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id])
  users          User[]
  projects       Project[]
  inquiries      Inquiry[]
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 3: catalog items and pricing
// ────────────────────────────────────────────────────────────

// Master catalog definitions behind every design option.
// category is a plain String (not enum) — open-ended list per data-model.md.
// attributes is untyped JSONB in Stage 3; typed contract deferred.
// See design-docs/04-data-model.md — Catalog & pricing.
model CatalogItem {
  id             String       @id @default(uuid())
  organizationId String
  category       String       // WALL_TYPE | GLASS | DOOR_TYPE | PROFILE_STOP | FRAME |
                              // HINGE | LOCKBOX | HANDLE | SEAL | RUBBER | FITTING | SCREW | …
  code           String
  name           String
  unitOfMeasure  String
  attributes     Json         // untyped JSONB — typed contract deferred to a later stage
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  prices         ItemPrice[]

  // Upsert key for seed idempotency
  @@unique([organizationId, code])
}

// Per-currency price for one catalog item within one org.
// Unique on (catalogItemId, currency) — one price per item per currency.
// See design-docs/04-data-model.md — ItemPrice notes.
model ItemPrice {
  id             String      @id @default(uuid())
  organizationId String
  catalogItemId  String
  currency       String      // ISO code, e.g. "AED", "USD"
  price          Decimal
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  catalogItem    CatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([catalogItemId, currency])
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 5: component types and projects
// ────────────────────────────────────────────────────────────

// Admin-defined grouping label for ComponentTypes (e.g. "Glass Partitions").
// Org-scoped; assignment is a dropdown backed by this table (not free text).
// See design-docs/04-data-model.md — ComponentType.
model ComponentCategory {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  componentTypes ComponentType[]

  @@unique([organizationId, name])
}

// Admin-defined field schema for a component category (GLASS, DOOR, PROFILE_STOP, …).
// fieldsSchema is JSONB containing field-list editor output — the shape is runtime-defined by admins.
// All ComponentTypes and fields are admin-created and inert until a developer wires them into the
// configurator (Stage 6+) — there is no developer-seeded/"core" distinction.
// See design-docs/04-data-model.md — ComponentType.
model ComponentType {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  code           String            // stable key, admin-defined at creation
  name           String            // admin-editable display label
  categoryId     String
  category       ComponentCategory @relation(fields: [categoryId], references: [id])
  fieldsSchema   Json              // JSONB field-list editor output
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  // Stage 6 relations
  selections     Selection[]

  @@unique([organizationId, code])
}

// Org-scoped project created by a user, optionally linked to an external company.
// projectNumber is a per-org integer sequence enforced at the app layer (MAX+1 in a transaction).
// See design-docs/04-data-model.md — Project.
model Project {
  id                 String           @id @default(uuid())
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id])
  externalCompanyId  String?
  externalCompany    ExternalCompany? @relation(fields: [externalCompanyId], references: [id])
  createdByUserId    String
  createdBy          User             @relation(fields: [createdByUserId], references: [id])
  projectNumber      Int              // per-org sequence; @@unique enforces collision safety
  name               String
  destinationCountry String
  currency           String
  status             String           // enum-like string; Stage 6 will tighten to a Prisma enum
  info               Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  // Stage 6 relations
  selections         Selection[]
  // Stage 7 relations
  inquiryId          String?
  inquiry            Inquiry?         @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  // Stage 8 relations
  floors             Floor[]

  @@unique([organizationId, projectNumber])
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 7: inquiries (lightweight pre-project entry point)
// ────────────────────────────────────────────────────────────

// Lightweight pre-project record. An Inquiry captures the same four fields
// as a Project (name, destinationCountry, currency, externalCompanyId?) but
// without committing to a full project workflow. It can be dismissed or
// converted into a Project (status → CONVERTED) via the "Start Project" action.
// inquiryNumber is a per-org integer sequence, enforced at the app layer (MAX+1
// in a transaction), mirroring Project.projectNumber.
// See design-docs/04-data-model.md — Inquiry.
model Inquiry {
  id                 String           @id @default(uuid())
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id])
  externalCompanyId  String?
  externalCompany    ExternalCompany? @relation(fields: [externalCompanyId], references: [id])
  createdByUserId    String
  createdBy          User             @relation(fields: [createdByUserId], references: [id])
  inquiryNumber      Int              // per-org sequence; @@unique enforces collision safety
  name               String
  destinationCountry String
  currency           String
  status             String           // "NEW" | "DISMISSED" | "CONVERTED"
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  projects           Project[]        // back-relation: Projects created by converting this Inquiry

  @@unique([organizationId, inquiryNumber])
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 8: floors and partitions (wall design)
// ────────────────────────────────────────────────────────────

// A logical level/area within a project (e.g. "Ground Floor", "Mezzanine").
// Floors are created implicitly by the add-wall form: if the entered label
// doesn't exist yet it's created; if it already exists the existing row is
// reused. orderIndex is app-managed (MAX+1 at insert time, per project).
// See design-docs/04-data-model.md — Floor.
model Floor {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  label          String
  orderIndex     Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id])
  partitions     Partition[]

  @@unique([projectId, label])
}

// A single wall (partition) within a floor. Users see "Wall" / "Add Wall";
// the DB entity is called Partition, matching the product's BOQ terminology.
// partitionNumber is a per-org sequence enforced at the app layer (MAX+1
// across all partitions for the project, regardless of floor) and backed by
// @@unique([organizationId, partitionNumber]) at the DB level — consistent with
// the Project.@@unique([organizationId, projectNumber]) pattern. This makes
// numbers org-wide unique (stronger than per-project intent, but achievable and
// collision-safe via P2002 on concurrent inserts). design is JSONB for the
// interactive canvas payload — populated in Stage 9, nullable for now.
// See design-docs/04-data-model.md — Partition.
model Partition {
  id              String       @id @default(uuid())
  organizationId  String
  floorId         String
  partitionNumber Int
  location        String
  heightMm        Int
  widthMm         Int
  status          String       @default("DRAFT")
  design          Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  floor           Floor        @relation(fields: [floorId], references: [id])

  @@unique([organizationId, partitionNumber])
}

// ────────────────────────────────────────────────────────────
// Domain models — Stage 6: selections (component instances on a project)
// ────────────────────────────────────────────────────────────

// A single component instance added to a project by a user.
// config captures the field values collected by the dynamic form (keyed by FieldEntry.key).
// orderIndex is an app-managed integer for display ordering (0-based, per project).
// See design-docs/04-data-model.md — Selection.
model Selection {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])
  componentTypeId String
  componentType   ComponentType @relation(fields: [componentTypeId], references: [id])
  label           String
  config          Json
  orderIndex      Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
