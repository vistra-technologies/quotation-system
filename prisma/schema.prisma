// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Stage 1 — trivial model to prove DB connectivity end-to-end.
// Not part of the real domain schema (that comes in a later stage).
model HealthCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

// Tenant root. Every tenant-scoped table will carry organizationId and filter
// on it (row-level tenancy). `slug` backs the per-org login page.
// See design-docs/04-data-model.md — Tenancy & identity.
model Organization {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
